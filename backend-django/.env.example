# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True

# Database (leave empty for SQLite, set for Postgres)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Google Maps API (needs Geocoding, Street View Static, Maps Static APIs enabled)
GOOGLE_MAPS_API_KEY=

# Detection thresholds
VACANCY_THRESHOLD=0.6
DEMOLITION_THRESHOLD=0.7

# Pipeline concurrency
GEOCODE_CONCURRENCY=8
IMAGERY_CONCURRENCY=6
DETECTION_WORKERS=4
PIPELINE_BATCH_SIZE=100
