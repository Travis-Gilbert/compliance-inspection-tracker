# Google Maps Platform API Key
# Enable: Street View Static API, Maps Static API, Geocoding API
GOOGLE_MAPS_API_KEY=your_api_key_here

# Database path (SQLite)
DATABASE_PATH=./data/compliance_tracker.db

# Image cache directory
IMAGE_CACHE_DIR=./data/images

# Image fetch settings
STREETVIEW_SIZE=640x480
SATELLITE_SIZE=640x480
SATELLITE_ZOOM=19

# Smart detection thresholds (0.0 - 1.0)
VACANCY_THRESHOLD=0.6
DEMOLITION_THRESHOLD=0.7

# Server
HOST=127.0.0.1
PORT=8000

# Frontend origins allowed to call the API
# Local example:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Railway example:
# CORS_ORIGINS=https://your-frontend.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
