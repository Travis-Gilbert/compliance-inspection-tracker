{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://backend-production-3996.up.railway.app/api/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "https://backend-production-3996.up.railway.app/images/$1"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
