{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-production-3996.up.railway.app/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://backend-production-3996.up.railway.app/images/:path*"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
